<% layout('layouts/boilerplate') %>

<div class="login-wrapper">
    <div class="row login-box g-0">
        <!-- Left Side -->
        <div class="col-md-6 position-relative left-panel">
            <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=1200" alt="Camping"
                class="img-fluid h-100 w-100 object-fit-cover">
            <div class="overlay-text">
                <h1>ExploreSphere</h1>
                <p>
                    Discover, share, and experience unforgettable camping trips.
                </p>
            </div>
        </div>

        <!-- Right Side -->
        <div class="col-md-6 bg-white d-flex align-items-center">
            <div class="form-container w-100">
                <h1 class="text-center fw-bold">
                    Welcome
                </h1>
                <p class="text-center text-muted mb-5">
                    Register to start your journey.
                </p>
                <form action="/register" method="POST" class="validated-form" novalidate>
                    <div class="mb-3">
                        <label class="form-label" for="username">Username</label>
                        <input class="form-control" type="text" id="username" name="username" required autofocus>
                        <!-- <div class="valid-feedback">
                            Looks good!
                        </div> -->
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="email">Email</label>
                        <input class="form-control" type="email" id="email" name="email" required>
                        <!-- <div class="valid-feedback">
                            Looks good!
                        </div> -->
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="password">Password</label>
                        <input class="form-control" type="password" id="password" name="password" required>
                        <!-- <div class="valid-feedback">
                            Looks good!
                        </div> -->
                    </div>
                    <button class="btn btn-success login-btn">Register</button>
                </form>
            </div>
        </div>
    </div>
</div>