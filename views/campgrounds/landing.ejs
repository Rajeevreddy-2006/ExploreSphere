<% layout('layouts/boilerplate') %>

<div class="container py-2">
    <div class="text-center mb-4">
        <h1 class="display-2 fw-bold"> Campgrounds Explorer </h1>
        <p class="lead mt-4 fs-4">
            Discover breathtaking camping destinations,
            connect with fellow adventurers,
            and share unforgettable outdoor experiences.
        </p>
        <div class="mt-5 d-flex flex-column flex-md-row justify-content-center gap-3">
            <a href="/campgrounds/all" class="btn btn-primary btn-lg px-5">
                Explore Campgrounds
            </a>
            <% if(currentUser){ %>
                <a href="/campgrounds/new" class="btn btn-success btn-lg px-5">
                    Add Campground
                </a>
            <% } %>
        </div>
    </div>
    <hr class="my-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2></h2>
                    <h4>Nature Escapes🌲</h4>
                    <p>
                        Explore beautiful forests, mountains,
                        lakes, and outdoor destinations.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2></h2>
                    <h4>Share Memories📸</h4>
                    <p>
                        Upload photos, document adventures,
                        and inspire other travelers.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2></h2>
                    <h4>Community Reviews⭐</h4>
                    <p>
                        Read authentic experiences and
                        discover highly rated campgrounds.
                    </p>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center mt-5">
        <h3>Ready for your next adventure?</h3>
        <p class="text-muted">
            Find the perfect campground and start exploring today.
        </p>
    </div>
</div>