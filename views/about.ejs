<% layout('layouts/boilerplate') %>

<div class="container py-2">
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">About ExploreSphere</h1>
        <p class="lead">
            Discover. Explore. Share.
        </p>
    </div>
    <div class="card shadow-sm p-5">
        <h2 class="mb-3">Our Mission</h2>
        <p>
            ExploreSphere is a community-driven platform designed to help travelers,
            explorers, and history enthusiasts discover remarkable destinations.
            From breathtaking campgrounds surrounded by nature to iconic heritage
            landmarks rich in history, ExploreSphere brings them together in one place.
        </p>
        <hr>
        <h2 class="mb-3">What You Can Explore</h2>
        <div class="row text-center mt-4">
            <div class="col-md-6 mb-4">
                <h3>🏕️ Campgrounds</h3>
                <p>
                    Discover scenic camping destinations, share outdoor experiences,
                    upload photos, and help fellow adventurers find their next getaway.
                </p>
            </div>
            <div class="col-md-6 mb-4">
                <h3>🏛️ Heritage Sites</h3>
                <p>
                    Explore temples, forts, monuments, and heritage sites while learning
                    about their history, cultural significance, and visitor experiences.
                </p>
            </div>
        </div>
        <hr>
        <h2 class="mb-3">Platform Features</h2>
        <div class="row">
            <div class="col-md-4">
                <h5>🗺️ Interactive Maps</h5>
                <p>Locate destinations with Mapbox-powered maps.</p>
            </div>
            <div class="col-md-4">
                <h5>📸 Photo Sharing</h5>
                <p>Upload and showcase memorable moments.</p>
            </div>
            <div class="col-md-4">
                <h5>⭐ Reviews</h5>
                <p>Read and contribute authentic visitor experiences.</p>
            </div>
        </div>
        <hr>
        <div class="text-center mt-4">
            <h3>Start Your Journey Today</h3>
            <p>
                Whether you're planning an outdoor adventure or exploring historical
                wonders, ExploreSphere helps you discover places worth remembering.
            </p>
        </div>
    </div>
</div>