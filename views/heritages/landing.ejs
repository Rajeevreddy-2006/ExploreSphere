<% layout('layouts/boilerplate') %>

<link rel="stylesheet" href="/stylesheets/heritageLanding.css">

<div class="container py-2">
    <div class="text-center mb-4">
        <h1 class="display-2 fw-bold">Heritage Explorer</h1>
        <p class="lead fs-4 mt-3">
            Journey through centuries of history, culture,
            architecture and heritage.
        </p>
        <p class="text-muted">
            Discover temples, forts, monuments and heritage landmarks
            from across Globe.
        </p>
    </div>
    <div class="row text-center mb-5">
        <div class="col-md-3">
            <h3>🛕</h3>
            <h5>Temples</h5>
            <p class="text-muted">Sacred destinations</p>
        </div>
        <div class="col-md-3">
            <h3>🏰</h3>
            <h5>Forts</h5>
            <p class="text-muted">Historic strongholds</p>
        </div>
        <div class="col-md-3">
            <h3>🏛️</h3>
            <h5>Monuments</h5>
            <p class="text-muted">Architectural wonders</p>
        </div>
        <div class="col-md-3">
            <h3>🌍</h3>
            <h5>Heritage Sites</h5>
            <p class="text-muted">Cultural treasures</p>
        </div>
    </div>
    <!-- Category Cards -->
    <div class="row g-4">
        <div class="col-md-6">
            <a href="/heritage/category/Temple" class="heritage-card">
                <!-- <div class="icon">🛕</div> -->
                <h2>Temple</h2>
                <p>
                    Discover ancient temples, sacred architecture,
                    and spiritual landmarks.
                </p>
                <span>Explore Temples →</span>
            </a>
        </div>
        <div class="col-md-6">
            <a href="/heritage/category/Fort" class="heritage-card">
                <!-- <div class="icon">🏰</div> -->
                <h2>Fort</h2>
                <p>
                    Explore historic forts, royal kingdoms,
                    and military strongholds.
                </p>
                <span>Explore Forts →</span>
            </a>
        </div>
        <div class="col-md-6">
            <a href="/heritage/category/Monument" class="heritage-card">
                <!-- <div class="icon">🏛️</div> -->
                <h2>Monument</h2>
                <p>
                    Visit iconic monuments and architectural
                    masterpieces.
                </p>
                <span>Explore Monuments →</span>
            </a>
        </div>
        <div class="col-md-6">
            <a href="/heritage/category/Heritage Site" class="heritage-card">
                <!-- <div class="icon">🌍</div> -->
                <h2>Heritage Site</h2>
                <p>
                    Experience UNESCO and culturally significant
                    heritage destinations.
                </p>
                <span>Explore Heritage Sites →</span>
            </a>
        </div>
    </div>
    <!-- Add Heritage Button -->
    <% if(currentUser){ %>
        <div class="text-center mt-5">
            <a href="/heritage/new" class="btn btn-success btn-lg px-5">
                Add Heritage Site
            </a>
        </div>
    <% } %>
</div>
