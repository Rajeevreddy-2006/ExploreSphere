<% layout('layouts/boilerplate') %>

<div id="cluster-map"></div>
<div class="container">
    <h1>All <%= category %>s</h1>
    <% for (let heritage of heritageSites) { %>
    <div class="card mb-3">
        <div class="row">
            <div class="col-md-4">
                <% if (heritage.images.length) { %>
                <img
                    class="img-fluid"
                    alt=""
                    src="<%= heritage.images[0].url %>">
                <% } else { %>
                <img
                    class="img-fluid"
                    alt=""
                    src="https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png">
                <% } %>
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= heritage.title %>
                    </h5>
                    <p class="card-text">
                        <%= heritage.description %>
                    </p>
                    <p class="card-text">
                        <small class="text-muted">
                            <%= heritage.location %>
                        </small>
                    </p>
                    <p class="card-text">
                        <small class="text-muted">
                            Category: <%= heritage.category %>
                        </small>
                    </p>
                    <a
                        class="btn btn-primary"
                        href="/heritage/<%= heritage._id %>">
                        View <%= heritage.title %>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</div>

<script>
    const mapToken = '<%- process.env.MAPBOX_TOKEN %>';
    const heritageSites = { features: <%- JSON.stringify(heritageSites) %>};
</script>

<script src="/javascripts/heritageClusterMap.js"></script>