<% layout('layouts/boilerplate') %>

<div class="row justify-content-center">
    <h1 class="text-center mb-4">Edit Heritage Site</h1>
    <div class="col-12 col-md-8 col-lg-6 mb-5">
        <form action="/heritage/<%= heritage._id %>?_method=PUT" method="POST" novalidate class="validated-form" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label" for="title"> Title </label>
                <input class="form-control" type="text" id="title" name="heritage[title]" value="<%= heritage.title %>" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="category"> Category </label>
                <select class="form-select" id="category" name="heritage[category]" required>
                    <option value="Temple" <%= heritage.category === 'Temple' ? 'selected' : '' %>>
                        Temple
                    </option>
                    <option value="Fort" <%= heritage.category === 'Fort' ? 'selected' : '' %>>
                        Fort
                    </option>
                    <option value="Monument" <%= heritage.category === 'Monument' ? 'selected' : '' %>>
                        Monument
                    </option>
                    <option value="Heritage Site" <%= heritage.category === 'Heritage Site' ? 'selected' : '' %>>
                        Heritage Site
                    </option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label" for="location"> Location </label>
                <input class="form-control" type="text" id="location" name="heritage[location]" value="<%= heritage.location %>" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label" for="description"> Description </label>
                <textarea class="form-control" id="description" name="heritage[description]" rows="4" required><%= heritage.description %></textarea>
                <div class="valid-feedback">
                    Looks good!
                </div>
            </div>
            <div class="input-group mb-3">
                <input type="file" class="form-control" id="image" name="image" multiple>
            </div>
            <div class="mb-3">
                <% heritage.images.forEach((img,i)=>{ %>
                    <div class="mb-3">
                        <img src="<%= img.thumbnail %>" class="img-thumbnail mb-2" style="max-width: 200px;" alt="">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="image-<%= i %>" name="deleteImages[]" value="<%= img.filename %>">
                            <label class="form-check-label" for="image-<%= i %>">
                                Delete Image
                            </label>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div class="d-flex flex-column flex-md-row gap-2 mt-3">
                <button class="btn btn-info w-100 w-md-auto">
                    Update Heritage Site
                </button>
                <a href="/heritage/<%= heritage._id %>" class="btn btn-secondary w-100 w-md-auto">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>